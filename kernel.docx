六、程序代码与执行结果
1、编写可载入内置模块：
#include <linux/module.h>
#include <linux/kernel.h>
#include <linux/fs.h>
#include <linux/cdev.h>
#include <linux/device.h>
#include <linux/uaccess.h>
#include <linux/slab.h>
#include <linux/mutex.h>
#define DEVICE_NAME "myringbuf"
#define CLASS_NAME  "myringbuf_class"
#define BUF_SIZE    4096
static dev_t devno;
static struct cdev my_cdev;
static struct class *my_class;
static struct device *my_device;
/* 环形缓冲区核心数据 */
static char ring_buffer[BUF_SIZE];
static int read_pos = 0;
static int write_pos = 0;
static int data_count = 0;
/* 防止多个进程同时读写造成数据混乱 */
static DEFINE_MUTEX(ring_lock);

static int my_open(struct inode *inode, struct file *file)
{
    printk(KERN_INFO "myringbuf: device opened\n");
    return 0;
}
static int my_release(struct inode *inode, struct file *file)
{
    printk(KERN_INFO "myringbuf: device closed\n");
    return 0;
}
static ssize_t my_write(struct file *file,
                        const char __user *buf,
                        size_t count,
                        loff_t *ppos)
{
    char *kbuf;
    size_t available;
    size_t to_write;//准备写多少个字节
    size_t i;
    if (count == 0)
        return 0;
    /*
     * 最多一次处理 BUF_SIZE 个字节。
     * 如果用户传入特别大的 count，不一次性申请太大内存。
     */
    if (count > BUF_SIZE)
        count = BUF_SIZE;
    kbuf = kmalloc(count, GFP_KERNEL);
    if (!kbuf)
        return -ENOMEM;
    mutex_lock(&ring_lock);
    available = BUF_SIZE - data_count;
    to_write = min(count, available);
    if (to_write == 0) {
        mutex_unlock(&ring_lock);
        kfree(kbuf);
        printk(KERN_INFO "myringbuf: buffer full, write ignored\n");
        return 0;
    }
    if (copy_from_user(kbuf, buf, to_write)) {
        mutex_unlock(&ring_lock);
        kfree(kbuf);
        return -EFAULT;
    }
    for (i = 0; i < to_write; i++) {
        ring_buffer[write_pos] = kbuf[i];
        write_pos = (write_pos + 1) % BUF_SIZE;
        data_count++;
    }
    mutex_unlock(&ring_lock);
    kfree(kbuf);
    printk(KERN_INFO "myringbuf: write %zu bytes, data_count=%d\n",
           to_write, data_count);
    return to_write;
}
static ssize_t my_read(struct file *file,
                       char __user *buf,
                       size_t count,
                       loff_t *ppos)
{
    char *kbuf;
    size_t to_read;//准备读多少个字节
    size_t i;

    if (count == 0)
        return 0;
    if (count > BUF_SIZE)
       count = BUF_SIZE;
    kbuf = kmalloc(count, GFP_KERNEL);
    if (!kbuf)
        return -ENOMEM;
    mutex_lock(&ring_lock);
    to_read = min(count, (size_t)data_count);
    if (to_read == 0) {
        mutex_unlock(&ring_lock);
        kfree(kbuf);
        printk(KERN_INFO "myringbuf: buffer empty, read returns 0\n");
        return 0;
    }
    for (i = 0; i < to_read; i++) {
        kbuf[i] = ring_buffer[read_pos];
        read_pos = (read_pos + 1) % BUF_SIZE;
        data_count--;
    }
    if (copy_to_user(buf, kbuf, to_read)) {
        mutex_unlock(&ring_lock);
        kfree(kbuf);
        return -EFAULT;
    }
    mutex_unlock(&ring_lock);
    kfree(kbuf);
    printk(KERN_INFO "myringbuf: read %zu bytes, data_count=%d\n",
           to_read, data_count);
    return to_read;
}
static struct file_operations fops = {
    .owner   = THIS_MODULE,
    .open    = my_open,
    .read    = my_read,
    .write   = my_write,
    .release = my_release,
};
static int __init myringbuf_init(void)
{
    int ret;
    ret = alloc_chrdev_region(&devno, 0, 1, DEVICE_NAME);
    if (ret < 0) {
        printk(KERN_ERR "myringbuf: failed to allocate device number\n");
        return ret;
    }
    cdev_init(&my_cdev, &fops);
    my_cdev.owner = THIS_MODULE;
    ret = cdev_add(&my_cdev, devno, 1);
    if (ret < 0) {
        unregister_chrdev_region(devno, 1);
        printk(KERN_ERR "myringbuf: failed to add cdev\n");
        return ret;
    }
    my_class = class_create(CLASS_NAME);
    if (IS_ERR(my_class)) {
        cdev_del(&my_cdev);
        unregister_chrdev_region(devno, 1);
        printk(KERN_ERR "myringbuf: failed to create class\n");
        return PTR_ERR(my_class);
    }
    my_device = device_create(my_class, NULL, devno, NULL, DEVICE_NAME);
    if (IS_ERR(my_device)) {
        class_destroy(my_class);
        cdev_del(&my_cdev);
        unregister_chrdev_region(devno, 1);
        printk(KERN_ERR "myringbuf: failed to create device\n");
        return PTR_ERR(my_device);
    }
    read_pos = 0;
    write_pos = 0;
    data_count = 0;
    printk(KERN_INFO "myringbuf: module loaded\n");
    printk(KERN_INFO "myringbuf: major=%d minor=%d\n",
           MAJOR(devno), MINOR(devno));
    printk(KERN_INFO "myringbuf: device created at /dev/%s\n", DEVICE_NAME);
    return 0;
}
static void __exit myringbuf_exit(void)
{
    device_destroy(my_class, devno);
    class_destroy(my_class);
    cdev_del(&my_cdev);
    unregister_chrdev_region(devno, 1);
    printk(KERN_INFO "myringbuf: module unloaded\n");
}
module_init(myringbuf_init);
module_exit(myringbuf_exit);
MODULE_LICENSE("GPL");
MODULE_AUTHOR("student");
MODULE_DESCRIPTION("A simple Linux character device driver with ring buffer");
2、把myringbuf.c编译成myringbuf.ko
cat > Makefile <<'EOF'
.RECIPEPREFIX := >
obj-m += myringbuf.o
KDIR := /lib/modules/$(shell uname -r)/build
PWD := $(shell pwd)
all:
>$(MAKE) -C $(KDIR) M=$(PWD) modules
clean:
>$(MAKE) -C $(KDIR) M=$(PWD) clean
EOF
3、加载内核模块：
sudo insmod myringbuf.ko


4、写writer代码：
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <fcntl.h>
#include <unistd.h>
#define DEVICE_PATH "/dev/myringbuf"
int main(){
    int fd;
    char msg[128];
    int i;
    ssize_t ret;//有符号整数ret（返回值），保存write的返回值，>0:实际读到的字节数，=0：没读到，<0:出错
    fd=open(DEVICE_PATH,O_WRONLY);
    for (i=1;i<=10;i++){
        snprintf(msg,sizeof(msg),"message %d from writer\n",i);
        ret=write(fd,msg,strlen(msg));
        printf("writer:write %zd bytes:%s",ret,msg);
        sleep(1);
    }
close(fd);
return 0;
}
5、reader代码：
#include <stdio.h>
#include <stdlib.h>
#include <fcntl.h>
#include <unistd.h>
#include <string.h>
#define DEVICE_PATH "/dev/myringbuf"
int main(){
    int fd;
    char buf[256];
    ssize_t ret;
    int i;
    fd=open(DEVICE_PATH,O_RDONLY);
    for (i=1;i<=15;i++){
        memset(buf,0,sizeof(buf));//把buf这个数组里的所有字节都设置成0，每次读取前清空旧数据
        ret=read(fd,buf,sizeof(buf)-1);//最多只读255个，剩下一个存’\0’
        if(ret==0){
           printf("reader:buffer empty,no data\n");
        }
        else{
           buf[ret]='\0';//手动添加字符串结束符
           printf("reader:read %zd bytes:%s",ret,buf);
        }
        sleep(1);
    }
    close(fd);
    return 0;
}
